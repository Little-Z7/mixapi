# ── mixapi 部署环境变量(cp 到 .env 后填写)────────────────────────────
# AES-256-GCM 主密钥,32 字节 = 64 位十六进制。生成:openssl rand -hex 32
# ⚠️ 强随机 + 永久固定保存!更换/丢失 = 已存账号密钥全部无法解密。切勿提交进 git。
MASTER_KEY=

# 控制台登录口令(不设则不启用 /admin 控制台)。用强口令。
ADMIN_KEY=

# 初始 gateway-key,客户端用作 Authorization: Bearer <此值>(也可上线后在控制台创建/轮换)
GATEWAY_KEY=

# 你的域名(Caddy 用它自动申请 HTTPS 证书);需先把该域名 A 记录解析到本服务器
DOMAIN=

# 容器内监听端口,一般无需修改
PORT=8080

# DB_PATH 默认由镜像设为 /data/mixapi.sqlite(挂到 docker 卷),Docker 部署无需在此设置。
# 纯本地/无域名调试时可加下面这行允许 http 登录控制台(生产勿用):
# ADMIN_INSECURE_COOKIE=1
